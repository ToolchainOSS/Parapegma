{
	auto_https off
	admin off
	persist_config off

	servers {
		timeouts {
			read_header 30s
			read_body   5m
			write       0		# 0 = no timeout (required for SSE streams)
			idle        30m		# default 5m — raised for long-lived connections
		}
	}
}

:8080 {
	# Reverse proxy API requests to backend with SSE streaming support.
	# handle_path strips the /api prefix before forwarding to the backend,
	# because the backend registers routes at root (e.g. /healthz, /dashboard).
	handle_path /api/* {
		reverse_proxy {$BACKEND_UPSTREAM:flow:8000} {
			flush_interval -1

			transport http {
				dial_timeout             30s	# default 10s  — connect to upstream
				response_header_timeout  0		# 0 = no timeout — wait for upstream headers
				keepalive                120s	# keep upstream conns alive
				keepalive_idle_conns     64
			}
		}
	}

	# Serve static frontend files with SPA deep-link fallback
	handle {
		root * /srv
		encode gzip zstd
		try_files {path} /index.html
		file_server
	}
}
