# ─── Runtime environment ──────────────────────────────────────────────
H4CKATH0N_ENV=development
H4CKATH0N_DATABASE_URL=sqlite+aiosqlite:///./data/flow-app.db
H4CKATH0N_RP_ID=localhost
H4CKATH0N_ORIGIN=http://localhost:8080
VITE_API_BASE_URL=/api

# Production (behind Cloudflare Tunnel):
# H4CKATH0N_RP_ID=example.com
# H4CKATH0N_ORIGIN=https://example.com

# ─── Ports ────────────────────────────────────────────────────────────
# WEB_PORT overrides PORT for flow-web (Caddy); default 8080.
# API_PORT overrides PORT for the backend (FastAPI); default 8000.
# PORT is a fallback for both (useful on platforms like Railway).
# WEB_PORT=8080
# API_PORT=8000
# PORT=8080

# ─── Backend ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# FLOW_DATA_DIR=/app/data       # defaults to /app/data in-container, ./data otherwise
# FLOW_WORKER_ID=               # defaults to hostname
# FLOW_PROMPTS_DIR=             # optional prompt override dir; falls back to mounted then baked prompts
# FLOW_BAKED_PROMPTS_DIR=       # image-baked fallback prompt dir outside /app (default /opt/flow/prompts)
# TZ=America/Toronto            # default IANA timezone

# ─── LLM ──────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
# OpenAI API key — enables live LLM responses. Without it the engine runs
# in deterministic stub mode. The backend accepts either name; keep secret.
OPENAI_API_KEY=
# H4CKATH0N_OPENAI_API_KEY=

# ─── Cryptographic master key ──────────────────────────────────────────
# Required for 4-condition assignment and anonymous Spark research telemetry.
# Generate exactly 32 random bytes, Base64URL-encode them without padding, and
# retain one value for the entire study. Never log, commit, or rotate it mid-study.
# Example: python -c 'import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode().rstrip("="))'
FLOW_CRYPTO_MASTER_KEY=

# ─── Web Push (VAPID) ─────────────────────────────────────────────────
# Generate with:  python -m py_vapid --gen
#             or: npx web-push generate-vapid-keys
# Push delivery is disabled if either key is empty.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_SUB=mailto:admin@example.com
# FLOW_VAPID_PUBLIC_KEY=        # legacy alias
# FLOW_VAPID_PRIVATE_KEY=       # legacy alias
# FLOW_PUSH_GONE_410_THRESHOLD=2

# ─── Automated feedback loop ──────────────────────────────────────────
# ENABLE_AUTOMATED_FEEDBACK=true
# FEEDBACK_DELAY_MINUTES=120
# FEEDBACK_PROMPT_TEXT=How did this prompt work for you?
# FEEDBACK_OPTIONS=Works perfectly,Needs tweaks

# ─── Notes ────────────────────────────────────────────────────────────
# Email is stored on the upstream h4ckath0n User and edited in Settings.
# It is NEVER used for identity or login — passkeys only.
