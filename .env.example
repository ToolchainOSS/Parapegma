# h4ckath0n environment
H4CKATH0N_ENV=development
H4CKATH0N_DATABASE_URL=sqlite+aiosqlite:///./data/myproject.db
H4CKATH0N_RP_ID=localhost
H4CKATH0N_ORIGIN=http://localhost:8080
VITE_API_BASE_URL=/api

# Application Configuration
LOG_LEVEL=INFO
# FLOW_DATA_DIR=/app/data # Defaults to /app/data in container, or ./data locally
# FLOW_WORKER_ID= # Defaults to hostname

# LLM Configuration
LLM_MODEL=gpt-4o-mini

# OpenAI API key — enables live LLM responses (stub mode without it).
# The backend checks both names. Keep this value secret and never commit it.
OPENAI_API_KEY=
# H4CKATH0N_OPENAI_API_KEY=   # Optional alternative name recognized by h4ckath0n

# VAPID keys for Web Push notifications.
# Generate with:  python -m py_vapid --gen
# or:  npx web-push generate-vapid-keys
# Copy the public/private key pair here.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_SUB=mailto:admin@example.com
# FLOW_VAPID_PUBLIC_KEY=   # Optional legacy alias
# FLOW_VAPID_PRIVATE_KEY=  # Optional legacy alias
# FLOW_PUSH_GONE_410_THRESHOLD=2  # Consecutive 410s before revoking a push subscription

# Email is stored at the user level in upstream h4ckath0n User.email.
# It is collected during registration and editable in Settings.
# Email is NOT used for identity or login — passkeys only.

# Production (behind Cloudflare Tunnel):
# H4CKATH0N_RP_ID=example.com
# H4CKATH0N_ORIGIN=https://example.com
